#!/bin/env python
import popplerqt5
import argparse
import PyQt5
from pathlib import Path
import os, sys, re

def sanitize(name):
    words = list(filter(None, re.split("[, \-!?:]+", name)))
    print(words)
    return "-".join(words)

def extract_from_marks(path):
    link_re = re.compile(r'\[([^\]]+)\]\(([^)]+)\)')

    with open(path, "r") as f:
        return list(link_re.findall(f.read()))
            

def extract_from_pdf(file):
    # get output path
    paper_path = os.environ.get('P')
    if not paper_path:
        sys.exit("Could not find environment $P")
    file_relative = "$P/" + str(Path(file).relative_to(paper_path))

    print("vim: set filetype=markdown.linked :\n")

    doc = popplerqt5.Poppler.Document.load(file)
    total_annotations = 0
    for i in range(doc.numPages()):
        page = doc.page(i)
        annotations = page.annotations()
        (pwidth, pheight) = (page.pageSize().width(), page.pageSize().height())
        if len(annotations) > 0:
            for annotation in annotations:
                if  isinstance(annotation, popplerqt5.Poppler.Annotation):
                    total_annotations += 1
                    if(isinstance(annotation, popplerqt5.Poppler.HighlightAnnotation)):
                        quads = annotation.highlightQuads()
                        txt = ""
                        link_txt = ""
                        for quad in quads:
                            rect = (quad.points[0].x() * pwidth,
                                    quad.points[0].y() * pheight,
                                    quad.points[2].x() * pwidth,
                                    quad.points[2].y() * pheight)
                            bdy = PyQt5.QtCore.QRectF()
                            bdy.setCoords(*rect)
                            new_txt = str(page.text(bdy)) 
                            txt = txt + new_txt + ' '

                            if len(new_txt) > len(link_txt):
                                link_txt = new_txt

                        txt = str(txt).strip()
                        if len(txt) > 20:
                            # format to max length of 80chars
                            sent_len = 0
                            words = []
                            for word in txt.split(" "):
                                if sent_len + len(word) > 80:
                                    print(" > {}".format(" ".join(words)))
                                    sent_len = 0
                                    words = []
                                else:
                                    words.append(word)
                                    sent_len += len(word) + 1
                            
                            if sent_len + len(" source") > 80:
                                print(" > {}".format(" ".join(words)))
                                print(" > [source]({}#{})\n".format(str(file_relative), link_txt))
                            else:
                                print(" > {} [source]({}#{})\n".format(" ".join(words), str(file_relative), link_txt))
                        else:
                            print(" > [{}]({}#{})\n".format(txt, str(file_relative), link_txt))

if __name__ == '__main__':
    parser = argparse.ArgumentParser()
    parser.add_argument('fn')
    args = parser.parse_args()

    # create sanitized filename from source
    path = Path(args.fn)
    filename = sanitize(path.stem)


    # extract all links from original source
    print(extract_from_marks(args.fn))

    #extract_from_pdf(args.fn)
